<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />
    <meta name="supported-color-schemes" content="light dark" />
    <title>{{ report.title }}</title>
    <style>
      body {
        margin: 0;
        padding: 0;
        background: #f3f5f7;
        color: #17212b;
        font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
        line-height: 1.5;
      }
      a {
        color: #0b5cab;
        text-decoration: none;
      }
      .container {
        max-width: 760px;
        margin: 0 auto;
        padding: 16px 10px 30px;
      }
      .panel {
        background: #ffffff;
        border: 1px solid #d9e1e8;
        border-radius: 14px;
        padding: 16px;
        margin-bottom: 12px;
      }
      .header {
        background: linear-gradient(135deg, #0f3f2f 0%, #18513d 100%);
      }
      .eyebrow {
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #597180;
        margin: 0 0 8px;
      }
      h1, h2, h3, p {
        margin-top: 0;
      }
      h1 {
        font-size: 30px;
        line-height: 1.1;
        margin-bottom: 8px;
      }
      h2 {
        font-size: 22px;
        margin-bottom: 6px;
      }
      h3 {
        font-size: 18px;
        margin-bottom: 8px;
      }
      .muted {
        color: #5a6d7c;
        font-size: 14px;
      }
      .header-line {
        color: #e2f2ea;
        font-size: 14px;
      }
      .header h1,
      .header .muted,
      .header .eyebrow,
      .header strong {
        color: #f0fbf6 !important;
      }
      .header h1 {
        color: #000000 !important;
      }
      .summary-box {
        background: #eef7ff;
        border-left: 4px solid #0b5cab;
        padding: 16px;
        border-radius: 10px;
      }
      .toc-list,
      .methodology-list,
      .narrative-list {
        margin: 0;
        padding-left: 18px;
      }
      .toc-list li,
      .methodology-list li,
      .narrative-list li {
        margin-bottom: 4px;
      }
      .repo-card {
        border-top: 1px solid #e4ebf1;
        padding-top: 12px;
        margin-top: 12px;
      }
      .repo-card:first-child {
        border-top: 0;
        padding-top: 0;
        margin-top: 0;
      }
      .repo-title {
        font-size: 18px;
        font-weight: 700;
      }
      .repo-title a {
        word-break: break-word;
      }
      .rank {
        display: inline-block;
        min-width: 28px;
        font-weight: 700;
        color: #0b5cab;
      }
      .meta,
      .score-row,
      .stats-row {
        color: #3f5362;
        font-size: 14px;
      }
      .tags {
        margin: 10px 0 8px;
      }
      .tag {
        display: inline-block;
        margin: 0 6px 6px 0;
        padding: 4px 9px;
        background: #f2f6f9;
        border: 1px solid #d8e3ec;
        border-radius: 999px;
        font-size: 12px;
        color: #365062;
      }
      .analysis-grid {
        display: block;
      }
      .forecast-card {
        border: 1px solid #d7e0e7;
        border-radius: 12px;
        padding: 10px;
        margin-bottom: 8px;
        background: #fbfcfd;
      }
      .footer {
        color: #6d7d89;
        font-size: 13px;
      }
      @media only screen and (max-width: 600px) {
        .panel {
          padding: 18px;
        }
        h1 {
          font-size: 25px;
        }
      }
      @media (prefers-color-scheme: dark) {
        body {
          background: #0f1722 !important;
          color: #eaf1f7 !important;
        }
        a {
          color: #78b8ff !important;
        }
        .panel {
          background: #162333 !important;
          border-color: #2a3b4f !important;
        }
        .header {
          background: linear-gradient(135deg, #0e3328 0%, #174736 100%) !important;
        }
        .eyebrow,
        .muted,
        .meta,
        .score-row,
        .stats-row,
        .footer,
        .header-line {
          color: #c7d5e3 !important;
        }
        .summary-box {
          background: #10233a !important;
          border-left-color: #78b8ff !important;
        }
        .repo-card {
          border-top-color: #2a3b4f !important;
        }
        .tag {
          background: #1f3042 !important;
          border-color: #33506a !important;
          color: #d8e8f7 !important;
        }
        .forecast-card {
          background: #132334 !important;
          border-color: #2f465d !important;
        }
      }
      [data-ogsc] body {
        background: #0f1722 !important;
        color: #eaf1f7 !important;
      }
      [data-ogsc] .panel {
        background: #162333 !important;
        border-color: #2a3b4f !important;
      }
      [data-ogsc] .header {
        background: #174736 !important;
      }
      [data-ogsc] .summary-box {
        background: #10233a !important;
        border-left-color: #78b8ff !important;
      }
      [data-ogsc] .eyebrow,
      [data-ogsc] .muted,
      [data-ogsc] .meta,
      [data-ogsc] .score-row,
      [data-ogsc] .stats-row,
      [data-ogsc] .footer,
      [data-ogsc] .header-line {
        color: #c7d5e3 !important;
      }
    </style>
  </head>
  <body>
    <div class="container">
      <div class="panel header">
        <p class="eyebrow">🎧 AudioRepoDigest</p>
        <h1>{{ report.title }}</h1>
        <p class="header-line">
          <strong>🗓️ Report period:</strong> {{ period_label }} |
          <strong>⏱️ Generated:</strong> {{ generated_at_label }} |
          <strong>👤 Recipient:</strong> {{ report.recipient_name }} |
          <strong>📊 Scanned:</strong> {{ report.metadata["raw_candidate_count"] }} raw, {{ report.scanned_candidate_count }} relevant, {{ report.selected_repo_count }} selected
        </p>
      </div>

      <div class="panel">
        <h2>🧭 Table of Contents</h2>
        <ul class="toc-list">
          {% for entry in report.toc %}
          <li><a href="#{{ entry.anchor }}">{{ entry.title }}</a></li>
          {% endfor %}
        </ul>
      </div>

      {% for section in report.sections %}
      <div class="panel" id="{{ section.anchor }}">
        <h2>{{ section.title }}</h2>
        {% if section.entries %}
          {% for ranked in section.entries %}
          {% set repo = ranked.candidate %}
          <div class="repo-card">
            <div class="repo-title">
              <span class="rank">#{{ ranked.rank }}</span>
              <a href="{{ repo.html_url }}">{{ repo.full_name }}</a>
            </div>
            <p>📝 {{ repo.description or "No description provided." }}</p>
            <div class="tags">
              {% for tag in repo.primary_tags %}
              <span class="tag">{{ tag.replace("_", " ") }}</span>
              {% endfor %}
            </div>
          </div>
          {% endfor %}
        {% else %}
          <p>No repositories qualified for this section in the current window.</p>
        {% endif %}
      </div>
      {% endfor %}

      {% if report.trend_analysis %}
      <div class="panel" id="trend-analysis">
        <h2>📈 Comprehensive Analysis of the Week's Trends</h2>
        <p><strong>{{ report.trend_analysis.headline }}</strong></p>
        <ul class="narrative-list">
          {% for paragraph in report.trend_analysis.narrative_sections[:2] %}
          <li>{{ paragraph }}</li>
          {% endfor %}
        </ul>
      </div>
      {% endif %}

      {% if report.forecast_section %}
      <div class="panel" id="forecasts">
        <h2>🔮 {{ report.forecast_section.headline }}</h2>
        <p>{{ report.forecast_section.intro }}</p>
        <div class="analysis-grid">
          {% for item in report.forecast_section.items %}
          <div class="forecast-card">
            <h3>{{ item.title }}</h3>
            <p>{{ item.estimate }}</p>
          </div>
          {% endfor %}
        </div>
      </div>
      {% endif %}

      <div class="footer">
        Generated by AudioRepoDigest v{{ report.version }}.
        <br />
        Want to generate your own customized automated, scheduled report like this?
        Check out my repo at
        <a href="https://github.com/TheColby/AudioRepoDigest">https://github.com/TheColby/AudioRepoDigest</a>.
      </div>
    </div>
  </body>
</html>
