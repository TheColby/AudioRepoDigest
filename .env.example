GITHUB_TOKEN=ghp_your_github_token

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=colbyleider@gmail.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=AudioRepoDigest <colbyleider@gmail.com>
SMTP_USE_STARTTLS=true
SMTP_USE_SSL=false

REPORT_RECIPIENT_EMAIL=colbyleider@gmail.com
REPORT_RECIPIENT_NAME=Colby Leider
REPORT_FREQUENCY=weekly
REPORT_CRON=0 13 * * 1
REPORT_TIMEZONE=America/New_York
REPORT_LOOKBACK_DAYS=7

TOP_N_MAIN=10
TOP_N_NEW=7
TOP_N_AUDIO_AI=7

INCLUDE_SUMMARIES=true
INCLUDE_HONORABLE_MENTIONS=true
INCLUDE_TREND_ANALYSIS=true
INCLUDE_FORECASTS=true
SUPPRESS_HONORABLE_MENTION_DUPLICATES=true

MAX_CANDIDATES_TO_SCAN=180
GITHUB_SEARCH_WINDOW_DAYS=21
README_FALLBACK_LIMIT=6

LOG_LEVEL=INFO
EMAIL_SUBJECT_PREFIX=[AudioRepoDigest]
ALLOWLIST_TOPICS=audio,music,dsp,speech,synthesis
BLOCKLIST_TERMS=car audio,audiobook,podcast-player,discord bot

OUTPUT_HTML_PATH=artifacts/digest.html
OUTPUT_MARKDOWN_PATH=artifacts/digest.md
OUTPUT_JSON_PATH=artifacts/digest.json

